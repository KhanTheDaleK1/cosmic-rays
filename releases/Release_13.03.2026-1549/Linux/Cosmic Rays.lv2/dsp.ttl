@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix bufs:  <http://lv2plug.in/ns/ext/buf-size#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix opts:  <http://lv2plug.in/ns/ext/options#> .
@prefix param: <http://lv2plug.in/ns/ext/parameters#> .
@prefix patch: <http://lv2plug.in/ns/ext/patch#> .
@prefix pg:    <http://lv2plug.in/ns/ext/port-groups#> .
@prefix plug:  <https://beechen.site/plugins/cosmic-rays:> .
@prefix pprop: <http://lv2plug.in/ns/ext/port-props#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rsz:   <http://lv2plug.in/ns/ext/resize-port#> .
@prefix state: <http://lv2plug.in/ns/ext/state#> .
@prefix time:  <http://lv2plug.in/ns/ext/time#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix urid:  <http://lv2plug.in/ns/ext/urid#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

plug:ALGO
	a lv2:Parameter ;
	rdfs:label "Algorithm" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 10	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "Mosaic" ;
		rdf:value 0 ;
	], [
		rdfs:label "Seq" ;
		rdf:value 1 ;
	], [
		rdfs:label "Glide" ;
		rdf:value 2 ;
	], [
		rdfs:label "Haze" ;
		rdf:value 3 ;
	], [
		rdfs:label "Tunnel" ;
		rdf:value 4 ;
	], [
		rdfs:label "Strum" ;
		rdf:value 5 ;
	], [
		rdfs:label "Blocks" ;
		rdf:value 6 ;
	], [
		rdfs:label "Interrupt" ;
		rdf:value 7 ;
	], [
		rdfs:label "Arp" ;
		rdf:value 8 ;
	], [
		rdfs:label "Pattern" ;
		rdf:value 9 ;
	], [
		rdfs:label "Warp" ;
		rdf:value 10 ;
	] .

plug:ACTIVITY
	a lv2:Parameter ;
	rdfs:label "Activity" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:TIME
	a lv2:Parameter ;
	rdfs:label "Time" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SHAPE
	a lv2:Parameter ;
	rdfs:label "Shape" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:REPEATS
	a lv2:Parameter ;
	rdfs:label "Repeats" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:FILTER
	a lv2:Parameter ;
	rdfs:label "Filter" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SPACE
	a lv2:Parameter ;
	rdfs:label "Space" ;
	rdfs:range atom:Float ;
	lv2:default 0.3 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:MIX
	a lv2:Parameter ;
	rdfs:label "Mix" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:LOOP_LEVEL
	a lv2:Parameter ;
	rdfs:label "Loop Level" ;
	rdfs:range atom:Float ;
	lv2:default 0.8 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:MOD_RATE
	a lv2:Parameter ;
	rdfs:label "Mod Rate" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0.1 ;
	lv2:maximum 10 .

plug:MOD_DEPTH
	a lv2:Parameter ;
	rdfs:label "Mod Depth" ;
	rdfs:range atom:Float ;
	lv2:default 0.2 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:KILL_DRY
	a lv2:Parameter ;
	rdfs:label "Kill Dry" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:TRAILS
	a lv2:Parameter ;
	rdfs:label "Trails" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:RESONANCE
	a lv2:Parameter ;
	rdfs:label "Resonance" ;
	rdfs:range atom:Float ;
	lv2:default 0.1 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:PITCH_DRIFT
	a lv2:Parameter ;
	rdfs:label "Pitch Drift" ;
	rdfs:range atom:Float ;
	lv2:default 0.2 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SNAP_STRENGTH
	a lv2:Parameter ;
	rdfs:label "Rhythmic Snap" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:TEMPO_MODE
	a lv2:Parameter ;
	rdfs:label "Tempo Sync" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:BPM
	a lv2:Parameter ;
	rdfs:label "Manual BPM" ;
	rdfs:range atom:Float ;
	lv2:default 120 ;
	lv2:minimum 30 ;
	lv2:maximum 300 .

plug:FREEZE
	a lv2:Parameter ;
	rdfs:label "Freeze/Sustain" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:SUBDIV
	a lv2:Parameter ;
	rdfs:label "Subdivision" ;
	rdfs:range atom:Float ;
	lv2:default 2 ;
	lv2:minimum 0 ;
	lv2:maximum 4	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "1/1" ;
		rdf:value 0 ;
	], [
		rdfs:label "1/2" ;
		rdf:value 1 ;
	], [
		rdfs:label "1/4" ;
		rdf:value 2 ;
	], [
		rdfs:label "1/8" ;
		rdf:value 3 ;
	], [
		rdfs:label "1/16" ;
		rdf:value 4 ;
	] .

plug:GAIN
	a lv2:Parameter ;
	rdfs:label "Output Gain" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0 ;
	lv2:maximum 2 .

plug:SPRAY
	a lv2:Parameter ;
	rdfs:label "Spray" ;
	rdfs:range atom:Float ;
	lv2:default 0.2 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SPREAD
	a lv2:Parameter ;
	rdfs:label "Spread" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:PITCH_JITTER
	a lv2:Parameter ;
	rdfs:label "Pitch Jitter" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 12 .

plug:WINDOW_TYPE
	a lv2:Parameter ;
	rdfs:label "Window Type" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 8	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "Sine" ;
		rdf:value 0 ;
	], [
		rdfs:label "Tri" ;
		rdf:value 1 ;
	], [
		rdfs:label "Saw" ;
		rdf:value 2 ;
	], [
		rdfs:label "Square" ;
		rdf:value 3 ;
	], [
		rdfs:label "Rand" ;
		rdf:value 4 ;
	], [
		rdfs:label "Hann" ;
		rdf:value 5 ;
	], [
		rdfs:label "Hamming" ;
		rdf:value 6 ;
	], [
		rdfs:label "Gaussian" ;
		rdf:value 7 ;
	], [
		rdfs:label "Rect" ;
		rdf:value 8 ;
	] .

plug:REV_PROB
	a lv2:Parameter ;
	rdfs:label "Rev Prob" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:LOOPER_MODE
	a lv2:Parameter ;
	rdfs:label "Looper Routing" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0 ;
	lv2:maximum 3	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "LOOPER ONLY" ;
		rdf:value 0 ;
	], [
		rdfs:label "PARALLEL" ;
		rdf:value 1 ;
	], [
		rdfs:label "FX -> LOOPER" ;
		rdf:value 2 ;
	], [
		rdfs:label "LOOPER -> FX" ;
		rdf:value 3 ;
	] .

plug:LOOPER_REC
	a lv2:Parameter ;
	rdfs:label "Looper Record" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:LOOPER_ODUB
	a lv2:Parameter ;
	rdfs:label "Looper Overdub" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:LOOPER_QUANT
	a lv2:Parameter ;
	rdfs:label "Quantize" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:LOOPER_REV
	a lv2:Parameter ;
	rdfs:label "Reverse" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:MASTER_WET_VOL
	a lv2:Parameter ;
	rdfs:label "Effect Volume" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0 ;
	lv2:maximum 2 .

plug:REVERB_MODE
	a lv2:Parameter ;
	rdfs:label "Reverb Mode" ;
	rdfs:range atom:Float ;
	lv2:default 2 ;
	lv2:minimum 0 ;
	lv2:maximum 3	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "ROOM" ;
		rdf:value 0 ;
	], [
		rdfs:label "MEDIUM" ;
		rdf:value 1 ;
	], [
		rdfs:label "HALL" ;
		rdf:value 2 ;
	], [
		rdfs:label "AMBIENT" ;
		rdf:value 3 ;
	] .

plug:LOOP_FADE
	a lv2:Parameter ;
	rdfs:label "Loop Fade" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:input_group_1
	a pg:InputGroup ;
	lv2:name "Input" ;
	lv2:symbol "input_group_1" .

plug:output_group_1
	a pg:OutputGroup ;
	lv2:name "Output" ;
	lv2:symbol "output_group_1" .

<https://beechen.site/plugins/cosmic-rays>
	ui:ui <https://beechen.site/plugins/cosmic-rays:UI> ;
	a lv2:Plugin ;
	doap:name "Cosmic Rays" ;
	doap:description "Cosmic Rays" ;
	lv2:minorVersion 0 ;
	lv2:microVersion 1 ;
	doap:maintainer [
		a foaf:Person ;
		foaf:name "Beechem" ;
		foaf:homepage <> ;
		foaf:mbox <> ;
	] ;
	doap:release [
		a doap:Version ;
		doap:revision "0.0.1" ;
	] ;
	lv2:optionalFeature
		lv2:hardRTCapable ;
	lv2:extensionData
		state:interface ;
	lv2:requiredFeature
		urid:map ,
		opts:options ,
		bufs:boundedBlockLength ;
	pg:mainInput plug:input_group_1 ;
	pg:mainOutput plug:output_group_1 ;
	patch:writable
		plug:ALGO ,
		plug:ACTIVITY ,
		plug:TIME ,
		plug:SHAPE ,
		plug:REPEATS ,
		plug:FILTER ,
		plug:SPACE ,
		plug:MIX ,
		plug:LOOP_LEVEL ,
		plug:MOD_RATE ,
		plug:MOD_DEPTH ,
		plug:KILL_DRY ,
		plug:TRAILS ,
		plug:RESONANCE ,
		plug:PITCH_DRIFT ,
		plug:SNAP_STRENGTH ,
		plug:TEMPO_MODE ,
		plug:BPM ,
		plug:FREEZE ,
		plug:SUBDIV ,
		plug:GAIN ,
		plug:SPRAY ,
		plug:SPREAD ,
		plug:PITCH_JITTER ,
		plug:WINDOW_TYPE ,
		plug:REV_PROB ,
		plug:LOOPER_MODE ,
		plug:LOOPER_REC ,
		plug:LOOPER_ODUB ,
		plug:LOOPER_QUANT ,
		plug:LOOPER_REV ,
		plug:MASTER_WET_VOL ,
		plug:REVERB_MODE ,
		plug:LOOP_FADE ;
	patch:readable
		plug:ALGO ,
		plug:ACTIVITY ,
		plug:TIME ,
		plug:SHAPE ,
		plug:REPEATS ,
		plug:FILTER ,
		plug:SPACE ,
		plug:MIX ,
		plug:LOOP_LEVEL ,
		plug:MOD_RATE ,
		plug:MOD_DEPTH ,
		plug:KILL_DRY ,
		plug:TRAILS ,
		plug:RESONANCE ,
		plug:PITCH_DRIFT ,
		plug:SNAP_STRENGTH ,
		plug:TEMPO_MODE ,
		plug:BPM ,
		plug:FREEZE ,
		plug:SUBDIV ,
		plug:GAIN ,
		plug:SPRAY ,
		plug:SPREAD ,
		plug:PITCH_JITTER ,
		plug:WINDOW_TYPE ,
		plug:REV_PROB ,
		plug:LOOPER_MODE ,
		plug:LOOPER_REC ,
		plug:LOOPER_ODUB ,
		plug:LOOPER_QUANT ,
		plug:LOOPER_REV ,
		plug:MASTER_WET_VOL ,
		plug:REVERB_MODE ,
		plug:LOOP_FADE ;
	lv2:port [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 0 ;
		lv2:symbol "audio_in_1" ;
		lv2:name "Audio In 1" ;
		pg:group plug:input_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#left> ;
	] , [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 1 ;
		lv2:symbol "audio_in_2" ;
		lv2:name "Audio In 2" ;
		pg:group plug:input_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#right> ;
	] , [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 2 ;
		lv2:symbol "audio_out_1" ;
		lv2:name "Audio Out 1" ;
		pg:group plug:output_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#left> ;
	] , [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 3 ;
		lv2:symbol "audio_out_2" ;
		lv2:name "Audio Out 2" ;
		pg:group plug:output_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#right> ;
	] , [
		a lv2:InputPort , atom:AtomPort ;
		rsz:minimumSize 10640 ;
		atom:bufferType atom:Sequence ;
		atom:supports
			midi:MidiEvent ,
			patch:Message ,
			time:Position ;
		lv2:designation lv2:control ;
		lv2:index 4 ;
		lv2:symbol "in" ;
		lv2:name "In" ;
	] , [
		a lv2:OutputPort , atom:AtomPort ;
		rsz:minimumSize 10640 ;
		atom:bufferType atom:Sequence ;
		atom:supports
			patch:Message ;
		lv2:designation lv2:control ;
		lv2:index 5 ;
		lv2:symbol "out" ;
		lv2:name "Out" ;
	] , [
		a lv2:OutputPort , lv2:ControlPort ;
		lv2:designation lv2:latency ;
		lv2:symbol "latency" ;
		lv2:name "Latency" ;
		lv2:index 6 ;
		lv2:portProperty lv2:reportsLatency , lv2:integer , lv2:connectionOptional , pprop:notOnGUI ;
		units:unit units:frame ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:designation lv2:freeWheeling ;
		lv2:symbol "freeWheeling" ;
		lv2:name "Free Wheeling" ;
		lv2:default 0.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
		lv2:index 7 ;
		lv2:portProperty lv2:toggled , lv2:connectionOptional , pprop:notOnGUI ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:designation lv2:enabled ;
		lv2:symbol "enabled" ;
		lv2:name "Enabled" ;
		lv2:default 1.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
		lv2:index 8 ;
		lv2:portProperty lv2:toggled , lv2:connectionOptional , pprop:notOnGUI ;
	] ;
	opts:supportedOption
		bufs:maxBlockLength .
