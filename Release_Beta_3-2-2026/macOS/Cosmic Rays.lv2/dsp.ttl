@prefix atom:  <http://lv2plug.in/ns/ext/atom#> .
@prefix bufs:  <http://lv2plug.in/ns/ext/buf-size#> .
@prefix doap:  <http://usefulinc.com/ns/doap#> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix midi:  <http://lv2plug.in/ns/ext/midi#> .
@prefix opts:  <http://lv2plug.in/ns/ext/options#> .
@prefix param: <http://lv2plug.in/ns/ext/parameters#> .
@prefix patch: <http://lv2plug.in/ns/ext/patch#> .
@prefix pg:    <http://lv2plug.in/ns/ext/port-groups#> .
@prefix plug:  <https://beechen.site/plugins/cosmic-rays:> .
@prefix pprop: <http://lv2plug.in/ns/ext/port-props#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rsz:   <http://lv2plug.in/ns/ext/resize-port#> .
@prefix state: <http://lv2plug.in/ns/ext/state#> .
@prefix time:  <http://lv2plug.in/ns/ext/time#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix units: <http://lv2plug.in/ns/extensions/units#> .
@prefix urid:  <http://lv2plug.in/ns/ext/urid#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

plug:ALGO
	a lv2:Parameter ;
	rdfs:label "Algorithm" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 10	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "Mosaic (Micro Loop)" ;
		rdf:value 0 ;
	], [
		rdfs:label "Seq (Micro Loop)" ;
		rdf:value 1 ;
	], [
		rdfs:label "Glide (Micro Loop)" ;
		rdf:value 2 ;
	], [
		rdfs:label "Haze (Granules)" ;
		rdf:value 3 ;
	], [
		rdfs:label "Tunnel (Granules)" ;
		rdf:value 4 ;
	], [
		rdfs:label "Strum (Granules)" ;
		rdf:value 5 ;
	], [
		rdfs:label "Blocks (Glitch)" ;
		rdf:value 6 ;
	], [
		rdfs:label "Interrupt (Glitch)" ;
		rdf:value 7 ;
	], [
		rdfs:label "Arp (Glitch)" ;
		rdf:value 8 ;
	], [
		rdfs:label "Pattern (Multidelay)" ;
		rdf:value 9 ;
	], [
		rdfs:label "Warp (Multidelay)" ;
		rdf:value 10 ;
	] .

plug:ACTIVITY
	a lv2:Parameter ;
	rdfs:label "Activity" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:TIME
	a lv2:Parameter ;
	rdfs:label "Time" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SHAPE
	a lv2:Parameter ;
	rdfs:label "Shape" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:REPEATS
	a lv2:Parameter ;
	rdfs:label "Repeats" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:FILTER
	a lv2:Parameter ;
	rdfs:label "Filter" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SPACE
	a lv2:Parameter ;
	rdfs:label "Space" ;
	rdfs:range atom:Float ;
	lv2:default 0.3 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:MIX
	a lv2:Parameter ;
	rdfs:label "Mix" ;
	rdfs:range atom:Float ;
	lv2:default 0.5 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:LOOP_LEVEL
	a lv2:Parameter ;
	rdfs:label "Loop Level" ;
	rdfs:range atom:Float ;
	lv2:default 0.8 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:RESONANCE
	a lv2:Parameter ;
	rdfs:label "Resonance" ;
	rdfs:range atom:Float ;
	lv2:default 0.1 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:MOD_RATE
	a lv2:Parameter ;
	rdfs:label "Mod Rate" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0.1 ;
	lv2:maximum 10 .

plug:MOD_DEPTH
	a lv2:Parameter ;
	rdfs:label "Mod Depth" ;
	rdfs:range atom:Float ;
	lv2:default 0.2 ;
	lv2:minimum 0 ;
	lv2:maximum 1 .

plug:SPACE_MODE
	a lv2:Parameter ;
	rdfs:label "Space Mode" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 3	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "Room" ;
		rdf:value 0 ;
	], [
		rdfs:label "Hall" ;
		rdf:value 1 ;
	], [
		rdfs:label "Ambient" ;
		rdf:value 2 ;
	], [
		rdfs:label "Wash" ;
		rdf:value 3 ;
	] .

plug:TEMPO_MODE
	a lv2:Parameter ;
	rdfs:label "Tempo Mode" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:SUBDIV
	a lv2:Parameter ;
	rdfs:label "Subdivision" ;
	rdfs:range atom:Float ;
	lv2:default 2 ;
	lv2:minimum 0 ;
	lv2:maximum 4	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "1/1" ;
		rdf:value 0 ;
	], [
		rdfs:label "1/2" ;
		rdf:value 1 ;
	], [
		rdfs:label "1/4" ;
		rdf:value 2 ;
	], [
		rdfs:label "1/8" ;
		rdf:value 3 ;
	], [
		rdfs:label "1/16" ;
		rdf:value 4 ;
	] .

plug:GAIN
	a lv2:Parameter ;
	rdfs:label "Master Gain" ;
	rdfs:range atom:Float ;
	lv2:default 1 ;
	lv2:minimum 0 ;
	lv2:maximum 2 .

plug:PRESET
	a lv2:Parameter ;
	rdfs:label "Preset" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 3	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "1" ;
		rdf:value 0 ;
	], [
		rdfs:label "2" ;
		rdf:value 1 ;
	], [
		rdfs:label "3" ;
		rdf:value 2 ;
	], [
		rdfs:label "4" ;
		rdf:value 3 ;
	] .

plug:LOOPER_MODE
	a lv2:Parameter ;
	rdfs:label "Looper Mode" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 2	 ;
	lv2:portProperty lv2:enumeration ;
	lv2:scalePoint [
		rdfs:label "Pre-FX" ;
		rdf:value 0 ;
	], [
		rdfs:label "Looper Only" ;
		rdf:value 1 ;
	], [
		rdfs:label "Burst" ;
		rdf:value 2 ;
	] .

plug:LOOPER_QUANT
	a lv2:Parameter ;
	rdfs:label "Quantize" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:LOOPER_REV
	a lv2:Parameter ;
	rdfs:label "Reverse" ;
	rdfs:range atom:Float ;
	lv2:default 0 ;
	lv2:minimum 0 ;
	lv2:maximum 1	 ;
	lv2:portProperty lv2:enumeration , lv2:toggled ;
	lv2:scalePoint [
		rdfs:label "Off" ;
		rdf:value 0 ;
	], [
		rdfs:label "On" ;
		rdf:value 1 ;
	] .

plug:input_group_1
	a pg:InputGroup ;
	lv2:name "Input" ;
	lv2:symbol "input_group_1" .

plug:output_group_1
	a pg:OutputGroup ;
	lv2:name "Output" ;
	lv2:symbol "output_group_1" .

<https://beechen.site/plugins/cosmic-rays>
	ui:ui <https://beechen.site/plugins/cosmic-rays:UI> ;
	a lv2:Plugin ;
	doap:name "Cosmic Rays" ;
	doap:description "Cosmic Rays" ;
	lv2:minorVersion 0 ;
	lv2:microVersion 1 ;
	doap:maintainer [
		a foaf:Person ;
		foaf:name "Beechem" ;
		foaf:homepage <> ;
		foaf:mbox <> ;
	] ;
	doap:release [
		a doap:Version ;
		doap:revision "0.0.1" ;
	] ;
	lv2:optionalFeature
		lv2:hardRTCapable ;
	lv2:extensionData
		state:interface ;
	lv2:requiredFeature
		urid:map ,
		opts:options ,
		bufs:boundedBlockLength ;
	pg:mainInput plug:input_group_1 ;
	pg:mainOutput plug:output_group_1 ;
	patch:writable
		plug:ALGO ,
		plug:ACTIVITY ,
		plug:TIME ,
		plug:SHAPE ,
		plug:REPEATS ,
		plug:FILTER ,
		plug:SPACE ,
		plug:MIX ,
		plug:LOOP_LEVEL ,
		plug:RESONANCE ,
		plug:MOD_RATE ,
		plug:MOD_DEPTH ,
		plug:SPACE_MODE ,
		plug:TEMPO_MODE ,
		plug:SUBDIV ,
		plug:GAIN ,
		plug:PRESET ,
		plug:LOOPER_MODE ,
		plug:LOOPER_QUANT ,
		plug:LOOPER_REV ;
	patch:readable
		plug:ALGO ,
		plug:ACTIVITY ,
		plug:TIME ,
		plug:SHAPE ,
		plug:REPEATS ,
		plug:FILTER ,
		plug:SPACE ,
		plug:MIX ,
		plug:LOOP_LEVEL ,
		plug:RESONANCE ,
		plug:MOD_RATE ,
		plug:MOD_DEPTH ,
		plug:SPACE_MODE ,
		plug:TEMPO_MODE ,
		plug:SUBDIV ,
		plug:GAIN ,
		plug:PRESET ,
		plug:LOOPER_MODE ,
		plug:LOOPER_QUANT ,
		plug:LOOPER_REV ;
	lv2:port [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 0 ;
		lv2:symbol "audio_in_1" ;
		lv2:name "Audio In 1" ;
		pg:group plug:input_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#left> ;
	] , [
		a lv2:InputPort , lv2:AudioPort ;
		lv2:index 1 ;
		lv2:symbol "audio_in_2" ;
		lv2:name "Audio In 2" ;
		pg:group plug:input_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#right> ;
	] , [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 2 ;
		lv2:symbol "audio_out_1" ;
		lv2:name "Audio Out 1" ;
		pg:group plug:output_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#left> ;
	] , [
		a lv2:OutputPort , lv2:AudioPort ;
		lv2:index 3 ;
		lv2:symbol "audio_out_2" ;
		lv2:name "Audio Out 2" ;
		pg:group plug:output_group_1 ;
		lv2:designation <http://lv2plug.in/ns/ext/port-groups#right> ;
	] , [
		a lv2:InputPort , atom:AtomPort ;
		rsz:minimumSize 9632 ;
		atom:bufferType atom:Sequence ;
		atom:supports
			midi:MidiEvent ,
			patch:Message ,
			time:Position ;
		lv2:designation lv2:control ;
		lv2:index 4 ;
		lv2:symbol "in" ;
		lv2:name "In" ;
	] , [
		a lv2:OutputPort , atom:AtomPort ;
		rsz:minimumSize 9632 ;
		atom:bufferType atom:Sequence ;
		atom:supports
			patch:Message ;
		lv2:designation lv2:control ;
		lv2:index 5 ;
		lv2:symbol "out" ;
		lv2:name "Out" ;
	] , [
		a lv2:OutputPort , lv2:ControlPort ;
		lv2:designation lv2:latency ;
		lv2:symbol "latency" ;
		lv2:name "Latency" ;
		lv2:index 6 ;
		lv2:portProperty lv2:reportsLatency , lv2:integer , lv2:connectionOptional , pprop:notOnGUI ;
		units:unit units:frame ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:designation lv2:freeWheeling ;
		lv2:symbol "freeWheeling" ;
		lv2:name "Free Wheeling" ;
		lv2:default 0.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
		lv2:index 7 ;
		lv2:portProperty lv2:toggled , lv2:connectionOptional , pprop:notOnGUI ;
	] , [
		a lv2:InputPort , lv2:ControlPort ;
		lv2:designation lv2:enabled ;
		lv2:symbol "enabled" ;
		lv2:name "Enabled" ;
		lv2:default 1.0 ;
		lv2:minimum 0.0 ;
		lv2:maximum 1.0 ;
		lv2:index 8 ;
		lv2:portProperty lv2:toggled , lv2:connectionOptional , pprop:notOnGUI ;
	] ;
	opts:supportedOption
		bufs:maxBlockLength .
