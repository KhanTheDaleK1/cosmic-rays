@prefix lv2:   <http://lv2plug.in/ns/lv2core#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix pset:  <http://lv2plug.in/ns/ext/presets#> .
@prefix state: <http://lv2plug.in/ns/ext/state#> .
@prefix ui:    <http://lv2plug.in/ns/extensions/ui#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .

<https://beechen.site/plugins/cosmic-rays>
	a lv2:Plugin ;
	lv2:binary <libCosmic%20Rays.so> ;
	rdfs:seeAlso <dsp.ttl> .

<https://beechen.site/plugins/cosmic-rays:UI>
	a ui:CocoaUI ;
	lv2:binary <libCosmic%20Rays.so> ;
	rdfs:seeAlso <ui.ttl> .

<https://beechen.site/plugins/cosmic-rays:preset1>
	a pset:Preset ;
	lv2:appliesTo <https://beechen.site/plugins/cosmic-rays> ;
	rdfs:label "" ;
	state:state [ <https://beechen.site/plugins/cosmic-rays:Program> "0"^^xsd:int ; ] .

